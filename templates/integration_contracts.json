{
  "name": "industrial_office_collaboration_integration_contracts",
  "version": "2026-06-17",
  "purpose": "Define safe handoff payloads for office-collaboration systems without claiming that external actions were already executed. Keep notification channels, approval systems, planning systems and engineering change systems clearly separated so production-led collaboration preserves real enterprise boundaries.",
  "systems": [
    {
      "target_system": "CMMS",
      "business_use": "Create or update a maintenance maintenance action record.",
      "action_types": ["create", "update", "evidence_attach", "notify"],
      "required_fields": [
        "action_record_title",
        "asset_or_line",
        "location",
        "event_time",
        "problem_description",
        "priority",
        "confirmed_facts",
        "next_actions",
        "acceptance_criteria"
      ],
      "authorization_required": false,
      "do_not_claim": ["dispatch_completed", "closed_completed", "repair_completed"]
    },
    {
      "target_system": "QMS",
      "business_use": "Create a quality isolation, recheck, or corrective-action record.",
      "action_types": ["create", "update", "approve_request", "evidence_attach", "notify"],
      "required_fields": [
        "batch_or_sku",
        "defect_description",
        "affected_quantity",
        "isolation_status",
        "quality_risk",
        "recheck_plan",
        "disposition_owner",
        "authorization_required"
      ],
      "authorization_required": true,
      "do_not_claim": ["quality_release_completed", "qualified_judgement_completed", "customer_acceptance_completed"]
    },
    {
      "target_system": "EHS",
      "business_use": "Create a safety finding, corrective action, or emergency coordination message.",
      "action_types": ["create", "notify", "evidence_attach", "update"],
      "required_fields": [
        "hazard_type",
        "location",
        "current_control",
        "risk_level",
        "qualified_owner",
        "verification_method",
        "followup_due_time"
      ],
      "authorization_required": true,
      "do_not_claim": ["hazardous_work_permit_completed", "safety_protection_bypass_allowed", "unsafe_live_work_allowed"]
    },
    {
      "target_system": "MES",
      "business_use": "Summarize production impact, changeover blockers, and recovery status.",
      "action_types": ["update", "notify", "evidence_attach"],
      "required_fields": [
        "line_or_station",
        "sku",
        "planned_or_actual_time",
        "production_impact",
        "blocking_reason",
        "responsible_department",
        "next_checkpoint"
      ],
      "authorization_required": false,
      "do_not_claim": ["production_recovery_completed", "parameter_approval_completed", "first_article_pass_completed"]
    },
    {
      "target_system": "SAP_ERP",
      "business_use": "Check or summarize material, spare-part, purchase, order, delivery, and cost impact.",
      "action_types": ["query", "update", "notify", "approve_request", "evidence_attach"],
      "required_fields": [
        "order_or_mrp_reference",
        "material_or_spare_part",
        "inventory_status",
        "purchase_or_transfer_status",
        "delivery_commitment",
        "cost_or_variance_impact",
        "planning_owner"
      ],
      "authorization_required": true,
      "do_not_claim": ["inventory_lock_completed", "purchase_approval_completed", "customer_delivery_commitment_completed", "cost_confirmation_completed"]
    },
    {
      "target_system": "ENTERPRISE_IM_EMAIL",
      "business_use": "Send a copy-ready message to Enterprise WeChat/WeCom, Feishu, DingTalk, or email for notification, reminder and meeting invitation only.",
      "action_types": ["notify", "remind", "escalate_notice"],
      "required_fields": [
        "audience",
        "message_summary",
        "responsible_parties",
        "due_time",
        "risks",
        "missing_information",
        "next_sync_time"
      ],
      "authorization_required": false,
      "do_not_claim": ["recipient_confirmation_completed", "approval_completed", "system_sync_completed", "formal_business_record_completed"]
    },
    {
      "target_system": "SOCIAL_EXTERNAL_COLLAB",
      "business_use": "Prepare one-click connector payloads for authorized WeChat, QQ, Weibo, customer-service or public-account channels used for external notification, customer/supplier feedback, and public-response coordination. These channels do not replace formal enterprise systems.",
      "action_types": ["notify", "feedback_collect", "escalate_notice", "public_response_draft"],
      "required_fields": [
        "platform",
        "authorized_account_scope",
        "recipient_scope",
        "message_summary",
        "redaction_scope",
        "feedback_contract",
        "business_record_backlink",
        "fallback_owner"
      ],
      "authorization_required": true,
      "do_not_claim": ["external_send_completed", "external_party_confirmation_completed", "formal_approval_completed", "business_closure_completed"]
    },
    {
      "target_system": "OA_APPROVAL",
      "business_use": "Create or update an abnormal report, approval flow, management escalation note, or cross-department meeting minutes in OA.",
      "action_types": ["create", "update", "approve_request", "evidence_attach", "notify"],
      "required_fields": [
        "event_id",
        "request_title",
        "business_reason",
        "decision_required",
        "decision_due_by",
        "owner_department",
        "approval_owner",
        "supporting_evidence"
      ],
      "authorization_required": true,
      "do_not_claim": ["approval_completed", "management_approval_completed", "meeting_decision_effective_completed", "customer_commitment_updated"]
    },
    {
      "target_system": "PMC_APS",
      "business_use": "Update or propose production planning, capacity, delivery, overtime, insert-order and recovery-window decisions.",
      "action_types": ["query", "update", "scenario_compare", "notify"],
      "required_fields": [
        "event_id",
        "line_or_capacity_reference",
        "affected_orders",
        "delivery_risk_level",
        "recovery_window",
        "alternative_schedule_options",
        "planning_owner",
        "decision_due_by"
      ],
      "authorization_required": false,
      "do_not_claim": ["delivery_commitment_completed", "customer_acceptance_completed", "schedule_switch_completed", "overtime_approval_completed"]
    },
    {
      "target_system": "PLM_ENGINEERING_CHANGE",
      "business_use": "Track temporary process change, parameter version, fixture/program change or engineering validation boundary.",
      "action_types": ["create", "update", "approve_request", "evidence_attach"],
      "required_fields": [
        "change_request_id",
        "product_or_sku",
        "current_version",
        "proposed_version_or_parameter",
        "change_reason",
        "validation_plan",
        "effective_scope",
        "engineering_owner"
      ],
      "authorization_required": true,
      "do_not_claim": ["parameter_effective_completed", "version_switch_completed", "first_article_pass_completed", "temporary_change_approval_completed"]
    },
    {
      "target_system": "KNOWLEDGE_BASE",
      "business_use": "Convert closed cases into reusable SOP notes, lessons learned, or checklists.",
      "action_types": ["knowledge_update"],
      "required_fields": [
        "case_summary",
        "verified_root_cause",
        "approved_countermeasure",
        "applicable_scope",
        "source_record",
        "review_owner"
      ],
      "authorization_required": true,
      "do_not_claim": ["root_cause_verified_completed", "sop_published_completed", "training_completed"]
    }
  ],
  "action_card_template": {
    "target_system": "",
    "action_type": "",
    "payload_summary": "",
    "evidence_ids": [],
    "required_fields": [],
    "missing_fields": [],
    "authorization_required": true,
    "readiness_status": "",
    "service_level_target": "",
    "business_decision_deadline": "",
    "idempotency_key": "",
    "channel_boundary": "",
    "preconditions": [],
    "post_submit_verification": [],
    "side_effect_boundary": [],
    "expected_receipt": {
      "external_record_id": "",
      "system_status": "",
      "submitted_at": "",
      "submitted_by_or_actor": "",
      "receipt_owner": ""
    },
    "cross_platform_connector": {
      "platform": "",
      "account_scope": "",
      "recipient_scope": "",
      "message_template": "",
      "feedback_contract": [],
      "audit_and_compliance": [],
      "business_record_backlink": ""
    },
    "failure_fallback": "",
    "rollback_or_followup": ""
  }
}
